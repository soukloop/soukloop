# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL Database URL for production
# Format: postgresql://username:password@host:port/database_name?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/soukloop_db?schema=public"

# For local development with SQLite (uncomment to use)
# DATABASE_URL="file:./dev.db"

# ===========================================
# NEXTAUTH CONFIGURATION
# ===========================================
# NextAuth.js configuration
# URL where your app is hosted (change for production)
NEXTAUTH_URL="http://localhost:3000"

# Secret key for NextAuth.js - generate a random string for production
# You can generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-key-change-this-in-production"

# ===========================================
# REDIS CONFIGURATION (Optional)
# ===========================================
# Redis connection settings for caching and rate limiting
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# ===========================================
# OAUTH PROVIDERS
# ===========================================
# Google OAuth Configuration
# Get these from: https://console.developers.google.com/
# 1. Create a new project
# 2. Enable Google+ API
# 3. Create OAuth 2.0 credentials
# 4. Add authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Apple OAuth Configuration
# Get these from: https://developer.apple.com/account/resources/identifiers/list
# 1. Create a new App ID
# 2. Create a new Service ID
# 3. Configure Sign in with Apple
# 4. Add redirect URL: http://localhost:3000/api/auth/callback/apple
APPLE_ID="your-apple-service-id"
APPLE_SECRET="your-apple-secret-key"

# Facebook OAuth Configuration
# Get these from: https://developers.facebook.com/apps/
# 1. Create a new app
# 2. Add Facebook Login product
# 3. Configure OAuth redirect URIs: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID="your-facebook-client-id"
FACEBOOK_CLIENT_SECRET="your-facebook-client-secret"

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Stripe API Keys
# Get these from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production
STRIPE_SECRET_KEY="sk_test_51..."
STRIPE_PUBLISHABLE_KEY="pk_test_51..."

# Stripe Webhook Secret
# Get this from: https://dashboard.stripe.com/webhooks
# Create a webhook endpoint pointing to: https://your-domain.com/api/webhooks/stripe
# Events to listen for: payment_intent.succeeded, payment_intent.payment_failed
STRIPE_WEBHOOK_SECRET="whsec_..."

# Stripe Webhook Endpoint (for reference)
# https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_ENDPOINT="https://your-domain.com/api/webhooks/stripe"

# ===========================================
# PAYPAL PAYMENT CONFIGURATION
# ===========================================
# PayPal API Credentials
# Get these from: https://developer.paypal.com/developer/applications/
# Use sandbox credentials for development, live credentials for production
PAYPAL_CLIENT_ID="your_paypal_client_id"
PAYPAL_CLIENT_SECRET="your_paypal_client_secret"

# PayPal Environment (sandbox or live)
PAYPAL_ENVIRONMENT="sandbox"

# PayPal Webhook Configuration
# Get these from: https://developer.paypal.com/developer/webhooks/
# Create a webhook pointing to: https://your-domain.com/api/webhooks/paypal
# Events to listen for: PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED
PAYPAL_WEBHOOK_ID="your_webhook_id"
PAYPAL_WEBHOOK_SECRET="your_webhook_secret"

# PayPal Webhook Endpoint (for reference)
PAYPAL_WEBHOOK_ENDPOINT="https://your-domain.com/api/webhooks/paypal"

# ===========================================
# COINBASE COMMERCE CONFIGURATION
# ===========================================
# Coinbase Commerce API
# Get these from: https://commerce.coinbase.com/dashboard/settings
# Use test API key for development, live API key for production
COINBASE_COMMERCE_API_KEY="your_api_key"
COINBASE_COMMERCE_WEBHOOK_SECRET="your_webhook_secret"

# Coinbase Commerce Webhook Endpoint (for reference)
# Create webhook at: https://commerce.coinbase.com/dashboard/settings
# Point to: https://your-domain.com/api/webhooks/crypto
COINBASE_WEBHOOK_ENDPOINT="https://your-domain.com/api/webhooks/crypto"

# ===========================================
# API CONFIGURATION
# ===========================================
# Server-only base URL for your backend API
API_BASE_URL="http://localhost:3000"

# Public base URL for client-side requests
NEXT_PUBLIC_API_BASE_URL="http://localhost:3000"

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# SMTP Configuration for email notifications
# Gmail example (use App Password, not regular password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
SMTP_FROM="noreply@your-domain.com"

# ===========================================
# FILE UPLOAD CONFIGURATION (Optional)
# ===========================================
# File upload settings
MAX_FILE_SIZE="10485760" # 10MB in bytes
UPLOAD_DIR="./uploads"

# AWS S3 Configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket"

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
# Rate limiting configuration
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_REDIS_URL="redis://localhost:6379"

# CORS configuration (comma-separated origins)
CORS_ORIGIN="http://localhost:3000,https://your-domain.com"

# ===========================================
# MONITORING & LOGGING (Optional)
# ===========================================
# Sentry for error tracking
# Get DSN from: https://sentry.io/settings/projects/
SENTRY_DSN="your-sentry-dsn"

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# ===========================================
# DEVELOPMENT CONFIGURATION
# ===========================================
# Development mode
NODE_ENV="development"

# Enable debug logging
DEBUG="false"

# ===========================================
# PRODUCTION CONFIGURATION (Uncomment for production)
# ===========================================
# Production settings
# NODE_ENV="production"
# NEXTAUTH_URL="https://your-domain.com"
# DATABASE_URL="postgresql://user:password@your-db-host:5432/soukloop_db"
# REDIS_HOST="your-redis-host"
# REDIS_PASSWORD="your-redis-password"
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# PAYPAL_ENVIRONMENT="live"
# COINBASE_COMMERCE_API_KEY="your_live_api_key"
